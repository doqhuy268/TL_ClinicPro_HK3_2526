# Database
DATABASE_URL="postgresql://username:password@localhost:5432/revita_db"

# JWT
JWT_SECRET="your_jwt_secret_key_here"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# Email Service (Resend) - Sẽ cấu hình sau
RESEND_API_KEY=""

# SMS Service (AWS SNS) - Sẽ cấu hình sau
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_SNS_TOPIC_ARN=""
# PayOS configuration
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_BASE_URL=https://api.payos.vn
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=
PAYOS_WEBHOOK_SECRET=
PAYOS_CREATE_PAYMENT_PATH=/v2/payments
# Email settings
# When true, do not send emails; only log to console (for dev/testing)
EMAIL_DRY_RUN=true

# Phạm vi tối giản (Desktop/Kiosk): tắt thanh toán online và SMS
DISABLE_PAYOS=true
DISABLE_SMS=true

# AI gợi ý chẩn đoán (service FastAPI/Python). Để trống thì POST /api/ai/suggest-diagnosis trả về []
RECOMMENDER_BASE_URL=
